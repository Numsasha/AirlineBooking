<Window x:Class="WpfApp2.PassengerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Кабинет пассажира" Height="600" Width="900" Loaded="Window_Loaded">
    <TabControl>
        <!-- ВКЛАДКА 1: ПОИСК И БРОНИРОВАНИЕ -->
        <TabItem Header="Поиск и бронирование">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="FlightsGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="FlightsGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Рейс" Binding="{Binding FlightNumber}" Width="*"/>
                        <DataGridTextColumn Header="Откуда" Binding="{Binding DepartureCity}" Width="*"/>
                        <DataGridTextColumn Header="Куда" Binding="{Binding ArrivalCity}" Width="*"/>
                        <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- ИНТЕРАКТИВНАЯ КАРТА МЕСТ -->
                <GroupBox Grid.Row="1" Header="Выберите место в салоне" Margin="0,10" Padding="10">
                    <ListBox x:Name="SeatsListBox" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Width="360"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="SeatBorder" Width="50" Height="40" Margin="5" CornerRadius="5" Background="LightGreen" BorderBrush="Gray" BorderThickness="1">
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </GroupBox>

                <Button Grid.Row="2" Content="Забронировать билет и скачать PDF" Click="Book_Click" Height="40" Background="#007ACC" Foreground="White" FontWeight="Bold"/>
            </Grid>
        </TabItem>

        <!-- ВКЛАДКА 2: МОИ БРОНИРОВАНИЯ -->
        <TabItem Header="Мои бронирования">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DataGrid x:Name="MyBookingsGrid" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID Брони" Binding="{Binding BookingID}" Width="*"/>
                        <DataGridTextColumn Header="Рейс" Binding="{Binding FlightNumber}" Width="*"/>
                        <DataGridTextColumn Header="Место" Binding="{Binding SeatNumber}" Width="*"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding BookingDate}" Width="2*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Button Grid.Row="1" Content="Отменить выбранное бронирование" Click="CancelBooking_Click" Height="35" Background="Red" Foreground="White" Margin="0,10,0,0"/>
            </Grid>
        </TabItem>
    </TabControl>
</Window>