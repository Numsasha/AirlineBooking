<Window x:Class="WpfApp2.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="Авторизация" Height="350" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Вход в систему" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Email:"/>
            <TextBox x:Name="EmailTextBox" Margin="0,5,0,15" Height="25"/>

            <TextBlock Text="Пароль:"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,5,0,20" Height="25"/>

            <Button Content="Войти" Click="LoginButton_Click" Height="35" Background="#007ACC" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
            <Button Content="Регистрация нового пассажира" Click="RegisterButton_Click" Height="30" Background="Transparent" BorderBrush="Gray"/>
        </StackPanel>
    </Grid>
</Window>
